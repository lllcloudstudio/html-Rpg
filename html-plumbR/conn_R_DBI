# Establish Connection Opt 3
# memory non-server sqlite , view with R libs

# Load DBI package
library(DBI)

# Example: Connect to an SQLite database (replace with your DB connection)
# For MySQL/PostgreSQL, use RMySQL::dbConnect() or RPostgres::dbConnect() OK--
con <- dbConnect(RSQLite::SQLite(), ":memory:")

# Example: Create a sample table
dbExecute(con, "CREATE TABLE employees (id INTEGER, name TEXT)")
dbExecute(con, "INSERT INTO employees VALUES (1, 'Alice'), (2, 'Bob')")

# 1. List all tables in the connection
tables <- dbListTables(con)
print(tables)

# 2. Select all rows from each table
for (tbl in tables) {
  # Use dbReadTable for a full table read
  data <- dbReadTable(con, tbl)
  cat("\nData from table:", tbl, "\n")
  print(data)
}

# Or, if you want to run a raw SQL query:
if (length(tables) > 0) {
  query <- paste0("SELECT * FROM ", tables[1])
  result <- dbGetQuery(con, query)
  cat("\nResult from first table:\n")
  print(result)
}

# Always disconnect when done
dbDisconnect(con)

















































